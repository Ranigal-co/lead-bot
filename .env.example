BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwXYZ
API_ID=0
API_HASH=0
PHONE_NUMBER=0
PHOTOGRAPHER_CHAT_ID=987654321

# Полный список для ФИЛЬТРАЦИИ постов
KEYWORDS=ищу фотографа,нужен фотограф,фотосессия,свадебный фотограф,фотограф на день рождения,фотограф на мероприятие,репортажная съёмка,предметная съёмка,контент для соцсетей,бизнес портрет,косплей,съёмка для бизнеса,фотограф на праздник

# Короткий список для ПОИСКА в VK (для скорости)
VK_KEYWORDS=фотограф,фотосессия,видеограф,съемка,репортаж,портрет,контент

CITIES=Москва
SEARCH_INTERVAL=300

# VK API — нужен USER access token (не сервисный!)
# Получить: python get_vk_token.py
VK_TOKEN=your_vk_user_token_here

# Публичные каналы Telegram для мониторинга (через запятую)
TG_CHANNELS=vakansii_bez_boltovni,rabotakastingi,mskeventjob,worldeventjob,spbeventjob,talentedpeoples,devjobs,msk_rabota

# GigaChat AI
GIGACHAT_CREDENTIALS=your_client_id:your_client_secret
AI_FILTER_ENABLED=false

# Режим: false = бесконечный цикл, true = один проход и выход
MOCK_MODE=false
